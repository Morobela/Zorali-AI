APP_NAME=Zorali AI
APP_ENV=local
SECRET_KEY=change-me-in-production

POSTGRES_USER=zorali
POSTGRES_PASSWORD=zorali
POSTGRES_DB=zorali_ai
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.2:1b
FRONTEND_URL=http://localhost:5173
PROJECT_ROOT=/app

JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=30

# Provider router
CLOUD_API_BASE=https://api.openai.com/v1
CLOUD_API_KEY=
CLOUD_MODEL=gpt-4o-mini
PROVIDER_TIMEOUT_SECONDS=60
WEB_SEARCH_ENABLED=false

# Rate limiting (OpenJarvis energy/cost + vLLM multi-user)
RATE_LIMIT_CAPACITY=60.0
RATE_LIMIT_REFILL=1.0

# Inference memory pool (vLLM PagedAttention-inspired)
MEMORY_POOL_BLOCKS=256
MEMORY_POOL_BLOCK_SIZE=512

# Batch processor concurrency (vLLM continuous batching)
BATCH_MAX_CONCURRENT=8

# Energy scoring (OpenJarvis cost-aware routing)
INFERENCE_COST_BUDGET_USD=10.0

# Local learning loop (OpenJarvis privacy-first self-improvement)
LEARNING_LOOP_ENABLED=true
LEARNING_MIN_IMPROVEMENT_PCT=2.0

# Task queue (Higgsfield experiment queue)
TASK_QUEUE_MAX_CONCURRENT=4
TASK_QUEUE_COST_BUDGET_USD=50.0

# Skills system (OpenJarvis modular skills)
SKILLS_AUTOLOAD=true

# Checkpoint persistence (TensorFlow SavedModel-inspired)
CHECKPOINT_ENABLED=true

APP_NAME=Zorali
APP_ENV=local
SECRET_KEY=change-me-in-production

POSTGRES_USER=zorali
POSTGRES_PASSWORD=zorali
POSTGRES_DB=zorali_ai
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.2:1b
FRONTEND_URL=http://localhost:5173
PROJECT_ROOT=/app
# Runtime data directory (uploaded file bytes, checkpoints, learning traces).
# Both compose stacks mount a volume at /data; leave as-is so all runtime data
# lands on that volume. Unset, uploads still probe /data but checkpoints and
# learning traces fall back to /app/data instead.
ZORALI_DATA_DIR=/data

JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=30

# Provider router
CLOUD_API_BASE=https://api.openai.com/v1
CLOUD_API_KEY=
CLOUD_MODEL=gpt-4o-mini
PROVIDER_TIMEOUT_SECONDS=60

# Deep research (multi-pass web search)
WEB_SEARCH_ENABLED=false
# Optional: Tavily API key (https://tavily.com). When set, deep research and
# the web_search tool use Tavily instead of the DuckDuckGo instant-answer API,
# which returns far richer results.
TAVILY_API_KEY=
# How many of the top search hits get fetched and read per research pass
DEEP_RESEARCH_MAX_PAGES=3
# Max characters of extracted text kept per fetched page
DEEP_RESEARCH_PAGE_CHARS=2400

# Sandboxed code execution (artifact ▶ Run, /run task command, code_execution tool).
# The sandbox is `python -I` in a subprocess with a clean env, temp cwd and a
# timeout — NOT a container: it cannot stop network or world-readable file
# access. Only enable on trusted single-admin deployments. Admin role required.
CODE_EXECUTION_ENABLED=false
CODE_EXECUTION_TIMEOUT_SECONDS=10

# Rate limiting (OpenJarvis energy/cost + vLLM multi-user)
RATE_LIMIT_CAPACITY=60.0
RATE_LIMIT_REFILL=1.0

# Inference memory pool (vLLM PagedAttention-inspired)
MEMORY_POOL_BLOCKS=256
MEMORY_POOL_BLOCK_SIZE=512

# Batch processor concurrency (vLLM continuous batching)
BATCH_MAX_CONCURRENT=8

# Energy scoring (OpenJarvis cost-aware routing)
INFERENCE_COST_BUDGET_USD=10.0

# Local learning loop (OpenJarvis privacy-first self-improvement)
LEARNING_LOOP_ENABLED=true
LEARNING_MIN_IMPROVEMENT_PCT=2.0

# Task queue (Higgsfield experiment queue)
TASK_QUEUE_MAX_CONCURRENT=4
TASK_QUEUE_COST_BUDGET_USD=50.0

# Skills system (OpenJarvis modular skills)
SKILLS_AUTOLOAD=true

# Checkpoint persistence (TensorFlow SavedModel-inspired)
CHECKPOINT_ENABLED=true

# Automatic memory: extract durable-fact candidates from chat turns into a
# pending Accept/Reject review queue (Memory panel).
AUTO_MEMORY_ENABLED=true

# Conversation titles: one-shot LLM call names each conversation after its
# first assistant reply (sidebar falls back to the opener preview).
AUTO_TITLES_ENABLED=true

# Context-window management: token budget for a session's history (cheap
# chars/4 estimate) and how many trailing messages stay verbatim once older
# turns get folded into the rolling per-session summary.
CONTEXT_MAX_TOKENS=6000
CONTEXT_KEEP_MESSAGES=8

# Hybrid retrieval (BM25 + TF-IDF + RRF + lexical feature reranking + optional dense)
# Chunks that reach the prompt per turn (always-on retrieval and the document_search tool)
RAG_TOP_K=3
RAG_RERANK_ENABLED=true
RAG_CANDIDATE_POOL=20
RAG_RRF_K=60
# Reranker boost weight — lexical features are a multiplicative boost, not primary signal
# formula: fused_norm × (1 + RAG_RERANK_WEIGHT × lexical_score)
RAG_RERANK_WEIGHT=0.5
# Top-N candidates from each individual ranker guaranteed to reach the reranking
# stage. Prevents dense-only results from being evicted by many weak lexical hits
# that each accumulate BM25+TF-IDF double votes. Set higher if dense candidates
# keep getting displaced by irrelevant lexical matches.
RAG_RANKER_GUARANTEE=5
# Weight given to dense rankings vs 1.0 per lexical ranker. Default 2.0 means dense
# gets equal total influence to BM25+TF-IDF combined, so a semantic top-1 can tie
# a lexical top-1 in the fused score instead of losing 1-vote-to-2.
RAG_DENSE_RRF_WEIGHT=3.0
RAG_CONTEXTUAL_ENABLED=true
# Optional dense embeddings via Ollama (off by default; requires nomic-embed-text pulled)
# Uses Nomic search_document/search_query task prefixes for correct retrieval mode.
RAG_EMBEDDINGS_ENABLED=false
RAG_EMBEDDING_MODEL=nomic-embed-text
